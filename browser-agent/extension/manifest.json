{
  "manifest_version": 3,
  "name": "ChromeBot Job Agent",
  "version": "0.1.0",
  "description": "Autonomous, rule-driven job application assistant",
  "permissions": ["storage", "tabs", "scripting", "activeTab"],
  "host_permissions": ["https://www.naukri.com/*", "https://api.openai.com/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.naukri.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ChromeBot"
  }
}
