{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Job Agent Runtime",
  "type": "object",
  "required": ["role", "locations", "experienceRange", "skills", "maxApplications"],
  "properties": {
    "role": { "type": "string", "minLength": 2 },
    "locations": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "experienceRange": {
      "type": "object",
      "required": ["min", "max"],
      "properties": {
        "min": { "type": "integer", "minimum": 0 },
        "max": { "type": "integer", "minimum": 0 }
      }
    },
    "skills": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "maxApplications": { "type": "integer", "minimum": 1, "maximum": 100 },
    "openaiApiKey": { "type": "string" }
  }
}
